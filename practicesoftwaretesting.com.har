tegories\",\n      \"hand-tools\": \"Hand Tools\",\n      \"power-tools\": \"Power Tools\",\n      \"other\": \"Other\",\n      \"special-tools\": \"Special Tools\",\n      \"rentals\": \"Rentals\",\n      \"contact\": \"Contact\",\n      \"sign-in\": \"Sign in\",\n      \"my-account\": \"My account\",\n      \"my-favorites\": \"My favorites\",\n      \"my-profile\": \"My profile\",\n      \"my-invoices\": \"My invoices\",\n      \"my-messages\": \"My messages\",\n      \"sign-out\": \"Sign out\"\n    }\n  },\n  \"footer\": {\n    \"demo-app\": \"This is a DEMO application\",\n    \"demo-purpose\": \"used for software testing training purpose.\"\n  },\n  \"pages\": {\n    \"overview\": {\n      \"filters\": \"Filters\",\n      \"sort\": \"Sort\",\n      \"sort-options\": {\n        \"name-asc\": \"Name (A - Z)\",\n        \"name-desc\": \"Name (Z - A)\",\n        \"price-desc\": \"Price (High - Low)\",\n        \"price-asc\": \"Price (Low - High)\",\n        \"co2-asc\": \"CO₂ Rating (A - E)\",\n        \"co2-desc\": \"CO₂ Rating (E - A)\"\n      },\n      \"price-range\": \"Price Range\",\n      \"search\": \"Search\",\n      \"categories\": \"Categories\",\n      \"by-category\": \"By category\",\n      \"category\": \"Category\",\n      \"brands\": \"Brands\",\n      \"by-brand\": \"By brand\",\n      \"no-results\": \"There are no products found.\",\n      \"no-stock\": \"Out of stock\",\n      \"sustainability\": \"Sustainability\",\n      \"eco-friendly\": \"Eco-Friendly Products\",\n      \"show-eco-friendly\": \"Show only eco-friendly products\",\n      \"co2-tooltip\": \"A = most environmentally friendly, E = higher environmental impact\"\n    },\n    \"product-detail\": {\n      \"photo-by\": \"Photo by\",\n      \"on\": \"on\",\n      \"add-to-cart-btn\": \"Add to cart\",\n      \"add-to-favorites-btn\": \"Add to favourites\",\n      \"per-hour\": \"per hour\",\n      \"increase-quantity\": \"Increase quantity\",\n      \"decrease-quantity\": \"Decrease quantity\",\n      \"quantity\": \"Quantity\",\n      \"total\": \"Total\",\n      \"duration\": \"Duration\",\n      \"hours\": \"hour(s)\",\n      \"related-products\": \"Related products\",\n      \"more-information\": \"More information\"\n    },\n    \"rentals\": {\n      \"title\": \"Rentals\"\n    },\n    \"login\": {\n      \"title\": \"Login\",\n      \"alternative\": \"or use\",\n      \"btn\": \"Login\",\n      \"generic-error\": \"Invalid email or password\",\n      \"no-account\": \"Not yet an account?\",\n      \"register\": \"Register your account\",\n      \"forgot-password\": \"Forgot your Password?\",\n      \"totp_code\": \"TOTP Code\",\n      \"verify_totp\": \"Verify TOTP\"\n    },\n    \"register\": {\n      \"title\": \"Customer registration\",\n      \"email-in-use\": \"Email is already in use.\",\n      \"btn\": \"Register\"\n    },\n    \"forgot-password\": {\n      \"title\": \"Forgot Password\",\n      \"btn\": \"Set New Password\",\n      \"confirm\": \"Your password is <strong>successfully</strong> updated!\"\n    },\n    \"contact\": {\n      \"title\": \"Contact\",\n      \"btn\": \"Send\",\n      \"subject\": {\n        \"label\": \"Subject\",\n        \"options\": {\n          \"select\": \"Select a subject *\",\n          \"customer-service\": \"Customer service\",\n          \"webmaster\": \"Webmaster\",\n          \"return\": \"Return\",\n          \"payments\": \"Payments\",\n          \"warranty\": \"Warranty\",\n          \"status-of-order\": \"Status of my order\"\n        },\n        \"errors\": {\n          \"required\": \"Subject is required\"\n        }\n      },\n      \"message\": {\n        \"label\": \"Message\",\n        \"errors\": {\n          \"required\": \"Message is required\",\n          \"minlength\": \"Message must be minimal 50 characters\"\n        }\n      },\n      \"attachment\": {\n        \"label\": \"Attachment\",\n        \"help\": \"Only files with the <strong>txt</strong> extension are allowed, and