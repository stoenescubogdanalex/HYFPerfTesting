            "text": "{\n  \"title\": \"Practice Software Testing\",\n  \"buttons\": {\n  },\n  \"chat\": {\n    \"title\": \"Chat Assistant\",\n    \"welcome\": \"Hi! How can I help you today?\",\n    \"menu\": {\n      \"find-product\": \"Find a product\",\n      \"order-product\": \"Order a product\",\n      \"checkout\": \"Checkout\",\n      \"support\": \"Create support ticket\"\n    },\n    \"find-product\": {\n      \"prompt\": \"What product are you looking for?\",\n      \"no-results\": \"No products found. Try a different search.\",\n      \"results\": \"Here are some products I found:\"\n    },\n    \"order-product\": {\n      \"search-prompt\": \"What product would you like to order? Type a product name to search.\",\n      \"no-results\": \"No products found. Try a different search.\",\n      \"select-product\": \"Here are some products I found. Click one to order:\",\n      \"selected\": \"Great choice! You selected:\",\n      \"quantity-prompt\": \"How many would you like to order?\",\n      \"other-quantity\": \"Other\",\n      \"enter-quantity\": \"Please enter the quantity you want:\",\n      \"invalid-quantity\": \"Please enter a valid number (1 or more).\",\n      \"quantity-too-high\": \"Maximum quantity is 999. Please enter a smaller number.\",\n      \"confirm-title\": \"Order Summary:\",\n      \"confirm-quantity\": \"Quantity:\",\n      \"confirm-total\": \"Total:\",\n      \"confirm-prompt\": \"Would you like to add this to your cart?\",\n      \"confirm-yes\": \"Yes, add to cart\",\n      \"change-quantity\": \"Change quantity\",\n      \"success\": \"Added to your cart!\",\n      \"what-next\": \"What would you like to do next?\",\n      \"continue-shopping\": \"Continue shopping\",\n      \"go-to-checkout\": \"Go to checkout\",\n      \"error\": \"Could not add to cart. Please try again.\"\n    },\n    \"support\": {\n      \"prompt\": \"I'll help you create a support ticket.\",\n      \"greeting-signed-in\": \"I see you're already signed in. Let's get started!\",\n      \"first-name-prompt\": \"What is your first name?\",\n      \"last-name-prompt\": \"What is your last name?\",\n      \"email-prompt\": \"What is your email address?\",\n      \"email-invalid\": \"Please enter a valid email address.\",\n      \"subject-prompt\": \"Please select a subject for your ticket:\",\n      \"subjects\": {\n        \"customer-service\": \"Customer service\",\n        \"webmaster\": \"Webmaster\",\n        \"return\": \"Return\",\n        \"payments\": \"Payments\",\n        \"warranty\": \"Warranty\",\n        \"status-of-order\": \"Status of my order\"\n      },\n      \"message-prompt\": \"Please describe your issue (minimum 50 characters):\",\n      \"message-too-short\": \"Your message must be at least 50 characters long.\",\n      \"attachment-prompt\": \"Would you like to add an attachment?\",\n      \"add-attachment\": \"Add attachment\",\n      \"skip-attachment\": \"Skip\",\n      \"attachment-invalid-type\": \"Only .txt files are allowed.\",\n      \"attachment-invalid-size\": \"File must be empty (0kb).\",\n      \"success\": \"Your support ticket has been submitted successfully! We'll get back to you soon.\",\n      \"error\": \"There was an error submitting your ticket:\"\n    },\n    \"checkout\": {\n      \"cart-empty\": \"Your cart is empty. Please add some products first.\",\n      \"cart-error\": \"Could not load your cart. Please try again.\",\n      \"cart-summary\": \"Your cart total:\",\n      \"login-or-guest\": \"Would you like to sign in or continue as guest?\",\n      \"login\": \"Sign in\",\n      \"guest\": \"Continue as guest\",\n      \"login-email-prompt\": \"Please enter your email address:\",\n      \"login-password-prompt\": \"Please enter your password:\",\n      \"login-success\": \"You're now signed in!\",\n      \"login-error\": \"Invalid email or password. Please try again.\",\n      \"try-again\": \"Try again\",\n      \"guest-email-prompt\": \"Please enter your email address for order confirmation:\",\n      \"guest-first-name-prompt\": \"Please enter your first name:\",\n      \"guest-last-name-prompt\": \"Please enter your last name:\",\n      \"invalid-email\": \"Please enter a valid email address.\",\n      \"address-street-prompt\": \"Please enter your street address:\",\n      \"address-city-prompt\": \"Please enter your city:\",\n      \"address-state-prompt\": \"Please enter your state/province:\",\n      \"address-country-prompt\": \"Please enter your country:\",\n      \"address-postcode-prompt\": \"Please enter your postal code:\",\n      \"address-confirm-title\": \"Please confirm your billing address:\",\n      \"address-confirm-prompt\": \"Is this address correct?\",\n      \"confirm\": \"Confirm\",\n      \"edit\": \"Edit\",\n      \"payment-method-prompt\": \"Please select your payment method:\",\n      \"payment-methods\": {\n        \"credit-card\": \"Credit Card\",\n        \"bank-transfer\": \"Bank Transfer\",\n        \"bnpl\": \"Buy Now Pay Later\",\n        \"gift-card\": \"Gift Card\",\n        \"cash-on-delivery\": \"Cash on Delivery\"\n      },\n      \"months\": \"months\",\n      \"card-number-prompt\": \"Please enter your credit card number (format: 0000-0000-0000-0000):\",\n      \"card-expiry-prompt\": \"Please enter the expiration date (format: MM/YYYY):\",\n      \"card-cvv-prompt\": \"Please enter the CVV (3 or 4 digits):\",\n      \"card-name-prompt\": \"Please enter the cardholder name:\",\n      \"invalid-card-number\": \"Invalid card number format. Use 0000-0000-0000-0000.\",\n      \"invalid-expiry\": \"Invalid expiration date format. Use MM/YYYY.\",\n      \"invalid-cvv\": \"Invalid CVV. Must be 3 or 4 digits.\",\n      \"invalid-card-name\": \"Cardholder name can only contain letters and spaces.\",\n      \"bank-name-prompt\": \"Please enter your bank name:\",\n      \"account-name-prompt\": \"Please enter the account holder name:\",\n      \"account-number-prompt\": \"Please enter your account number:\",\n      \"invalid-bank-name\": \"Bank name can only contain letters and spaces.\",\n      \"invalid-account-name\": \"Invalid account name format.\",\n      \"invalid-account-number\": \"Account number must contain only digits.\",\n      \"bnpl-prompt\": \"How many monthly installments would you like?\",\n      \"giftcard-number-prompt\": \"Please enter your gift card number:\",\n      \"giftcard-code-prompt\": \"Please enter the validation code:\",\n      \"invalid-giftcard-number\": \"Gift card number must be alphanumeric.\",\n      \"invalid-giftcard-code\": \"Validation code must be alphanumeric.\",\n      \"order-summary\": \"Order Summary:\",\n      \"total-label\": \"Total:\",\n      \"shipping-address\": \"Shipping to:\",\n      \"payment-label\": \"Payment method:\",\n      \"confirm-order-prompt\": \"Ready to place your order?\",\n      \"place-order\": \"Place Order\",\n      \"edit-payment\": \"Change payment method\",\n      \"processing\": \"Processing your order...\",\n      \"success\": \"Your order has been placed successfully!\",\n      \"order-number\": \"Order number:\",\n      \"what-next\": \"What would you like to do now?\",\n      \"view-orders\": \"View my orders\",\n      \"new-order\": \"Start new order\",\n      \"error\": \"There was an error processing your order:\",\n      \"payment-error\": \"Payment validation failed:\"\n    },\n    \"back\": \"Back to menu\",\n    \"placeholder\": \"Type your message...\"\n  },\n  \"fields\": {\n    \"email\": {\n      \"label\": \"Email address\",\n      \"placeholder\": \"Your email\",\n      \"errors\": {\n        \"required\": \"Email is required\",\n        \"format\": \"Email format is invalid\"\n      }\n    },\n    \"password\": {\n      \"label\": \"Password\",\n      \"placeholder\": \"Your password\",\n      \"errors\": {\n        \"required\": \"Password is required\",\n        \"length\": \"Password length is invalid\",\n        \"minlength\": \"Password must be minimal 