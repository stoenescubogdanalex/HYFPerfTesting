   \"account-name-error-format\": \"Account name can contain letters, numbers, spaces, periods, apostrophes, and hyphens.\",\n          \"account-number\": \"Account Number\",\n          \"account-number-help\": \"Please enter your bank account number as it appears on your bank statement. It's a unique series of numbers used to identify your individual account. Avoid including any spaces or hyphens.\",\n          \"account-number-error-format\": \"Account number must be numeric.\"\n        },\n        \"credit-card\": {\n          \"number\": \"Credit Card Number\",\n          \"number-help\": \"Enter your 16-digit credit card number as it appears on the card, in the format 0000-0000-0000-0000. Ensure that you include the hyphens for proper formatting.\",\n          \"number-error-format\": \"Invalid card number format.\",\n          \"expiration-date\": \"Expiration Date\",\n          \"date-error-format\": \"Invalid date format. Use MM/YYYY.\",\n          \"date-error-past\": \"Expiration date must be in the future.\",\n          \"cvv\": \"CVV\",\n          \"cvv-help\": \"The CVV is a 3-digit or 4-digit number. It's used for added security during card-not-present transactions.\",\n          \"cvv-error-format\": \"CVV must be 3 or 4 digits.\",\n          \"name\": \"Card Holder Name\",\n          \"name-required\": \"Only letters and spaces are allowed.\"\n        },\n        \"bnpl\": {\n          \"monthly-installments\": \"Monthly Installments\",\n          \"monthly-installments-choose\": \"Choose your monthly installments\",\n          \"monthly-installments-help\": \"This option allows you to spread the cost of your purchase over several months.\",\n          \"monthly-installments-error-required\": \"Please select the number of monthly installments.\"\n        },\n        \"gift-card\": {\n          \"number\": \"Gift Card Number\",\n          \"number-help\": \"Enter the unique number found on your gift card. This number is usually located on the back of the card and may consist of digits and/or letters.\",\n          \"number-error-format\": \"Gift card number must be alphanumeric.\",\n          \"validation-code\": \"Validation Code\",\n          \"validation-code-help\": \"The validation code is a security feature found on your gift card, often located near the gift card number. Enter this code exactly as it appears on your card.\",\n          \"validation-code-error-format\": \"Validation code must be alphanumeric.\"\n        }\n      }\n    },\n    \"my-account\": {\n      \"overview\": {\n        \"title\": \"My account\",\n        \"description\": \"Here you can manage your profile, favorites and orders.\",\n        \"favorites\": \"Favorites\",\n        \"profile\": \"Profile\",\n        \"invoices\": \"Invoices\",\n        \"messages\": \"Messages\"\n      },\n      \"profile\": {\n        \"title\": \"Profile\",\n        \"update-profile-btn\": \"Update Profile\",\n        \"update-profile-success\": \"Your profile is <strong>successfully</strong> updated!\",\n        \"password-section\": \"Password\",\n        \"current-password\": \"Current Password\",\n        \"new-password\": \"New Password\",\n        \"confirm-new-password\": \"Confirm New Password\",\n        \"change-password-btn\": \"Change Password\",\n        \"change-password-success\": \"Your password is <strong>successfully</strong> updated!\",\n        \"two_factor_authentication_enabled\": \"Two-Factor Authentication already enabled.\",\n        \"verify_totp\": \"Verify TOTP\",\n        \"enter_totp_code\": \"Enter TOTP code\",\n        \"manually_enter_key\": \"Or manually enter this key in your app:\",\n        \"scan_qr_code\": \"Scan the QR code below with your authenticator app (e.g., Google Authenticator, Authy):\",\n        \"setup_two_factor_authentication\": \"Set up Two-Factor Authentication\",\n        \"totp_verified\": \"TOTP verified and enabled successfully.\",\n        \"invalid_totp_code\": \"Invalid TOTP code. Please try again.\"\n      },\n      \"messages\": {\n        \"title\": \"Messages\",\n        \"no-messages\": \"There are no messages yet. Navigate to the <a class=\\\"link-primary\\\" id=\\\"contact-link\\\">contact form</a> and fill out the form.\",\n        \"subject\": \"Subject\",\n        \"message\": \"Message\",\n        \"status\": \"Status\",\n        \"date\": \"Date\",\n        \"details\": \"Details\",\n        \"back-btn\": \"Back\",\n        \"replies\": \"Replies\",\n        \"reply-btn\": \"Reply\",\n        \"add-reply\": \"Add Reply\"\n      },\n      \"favorites\": {\n        \"title\": \"Favorites\",\n        \"no-favorites\": \"There are no favorites yet. In order to add favorites, please go to the product listing and mark some products as your favorite.\"\n      },\n      \"invoices\": {\n        \"title\": \"Invoices\",\n        \"invoice-number\": \"Invoice Number\",\n        \"billing-address\": \"Billing Address\",\n        \"invoice-date\": \"Invoice Date\",\n        \"total\": \"Total\",\n        \"details\": \"Details\",\n        \"not-exist\": \"This invoice doesn't exist.\",\n        \"download-pdf\": \"Download PDF\",\n        \"general-information\": \"General Information\",\n        \"payment-information\": \"Payment Information\",\n        \"products\": \"Products\",\n        \"product\": \"Product\"\n      }\n    }\n  }\n}\n"
